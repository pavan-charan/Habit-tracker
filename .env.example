# Project Configuration
PROJECT_NAME=PersonalOS
ENVIRONMENT=development
LOG_LEVEL=INFO

# Backend Configuration (FastAPI)
BACKEND_PORT=8000
SECRET_KEY=change-this-super-secret-jwt-key-min-32-chars-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=personalos
POSTGRES_PASSWORD=personalos_secret_password
POSTGRES_DB=personalos_db
DATABASE_URL=postgresql+asyncpg://personalos:personalos_secret_password@localhost:5432/personalos_db

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Frontend Configuration (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=PersonalOS
